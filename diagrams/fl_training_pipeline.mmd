flowchart TD
    A["📂 39 TAWOS Project CSVs\none CSV = one client"] --> B["load_dataset_by_project\ncolumn normalization + text assembly"]
    B --> C["per-client train/test split\n80% train · 20% test"]
    C --> D["compute per-client z-score stats\nmean & std per project\n(training data only)"]
    D --> E["compute global stats\n(fallback for unknown clients at inference)"]

    D --> CLIENTS
    E --> CLIENTS

    subgraph CLIENTS["Client Setup"]
        direction LR
        CL1["Client 1\nnorm: own mean/std"]
        CL2["Client 2\nnorm: own mean/std"]
        CLD["· · ·"]
        CL39["Client 39\nnorm: own mean/std"]
    end

    CLIENTS --> FL

    subgraph FL["Federated Training  ·  75 rounds"]
        direction TB
        G["Initialize Global Model\nDistilBERT encoder + categorical embeddings + regression head"]
        G --> SEL["Pick ~10 clients per round\nclients_per_round_fraction = 0.25"]
        SEL --> LOC["Each selected client\n① load global weights\n② train on local z-score normalized data\n③ return updated weights + num_examples"]
        LOC --> AGG["FedAvg aggregation\nweighted average by num_examples"]
        AGG --> SEL
    end

    FL --> EVAL["Evaluate on held-out test set\nrun model → denormalize per client_id\ncompute MAE · RMSE · R²"]

    EVAL --> SAVE["Save Artifact\nmodel_state.pt  ·  tokenizer/\nmetadata.json\n(client_stats · global_stats · vocab maps)"]

    SAVE --> PRED

    subgraph PRED["Prediction  ·  predict_saved_model.py"]
        direction TB
        NI["New project CSV"] --> LA["Load artifact\n(model + tokenizer + client stats)"]
        LA --> INF["Model inference\noutput in normalized space"]
        INF --> DN["Denormalize per client_id\nfallback to global stats if client unseen"]
        DN --> OUT["Output CSV\npredicted_story_point per issue"]
    end
